{
  "info": {
    "_postman_id": "c6225b1b-9e4a-4d7a-8b35-8cf1a4b4139d",
    "name": "S-Park_Auth_Paciente",
    "description": "Colección para probar el flujo completo de autenticación de pacientes (Primer acceso) usando OTP.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login Paciente (Primer Acceso)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.requiresVerification) {",
              "    pm.environment.set(\"patient_email\", jsonData.email);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"paciente@ejemplo.com\",\n    \"password\": \"TEMP_PASSWORD_AQUI\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Utiliza la contraseña temporal generada (que llega al correo) para iniciar sesión."
      },
      "response": []
    },
    {
      "name": "2. Verificar OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{patient_email}}\",\n    \"codigo\": \"OTP_AQUI\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/verify-code",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "verify-code"
          ]
        },
        "description": "Verifica el código OTP de 6 dígitos enviado por correo."
      },
      "response": []
    },
    {
      "name": "3. Cambiar Contraseña Inicial",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.environment.set(\"auth_token\", jsonData.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{patient_email}}\",\n    \"newPassword\": \"MiNuevaPassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/change-initial-password",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "change-initial-password"
          ]
        },
        "description": "Establece la nueva contraseña definitiva. Devuelve el JWT tras el éxito."
      },
      "response": []
    },
    {
      "name": "4. Login Definitivo (Validación)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.environment.set(\"auth_token\", jsonData.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{patient_email}}\",\n    \"password\": \"MiNuevaPassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Comprueba que el login con la nueva contraseña funciona correctamente y devuelve el JWT de forma directa (sin pedir OTP)."
      },
      "response": []
    },
    {
      "name": "Reenviar OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{patient_email}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/resend-code",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "resend-code"
          ]
        },
        "description": "Solicita un nuevo código OTP en caso de que el anterior haya expirado."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "patient_email",
      "value": "",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ]
}
